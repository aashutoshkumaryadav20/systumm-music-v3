{
  "id": "/",
  "name": "Systumm Music",
  "short_name": "Systumm",
  "description": "Discover trending music, new releases and Hindi playlists with direct high-quality playback.",
  "lang": "en-IN",
  "dir": "ltr",
  "start_url": "/?source=pwa",
